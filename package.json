{
  "name": "prometheus-auto-instrument",
  "version": "1.0.1",
  "description": "Zero-config Prometheus instrumentation for Node.js",
  "main": "src/index.js",
  "type": "commonjs",
  "files": [
    "src",
    "bin",
    "dashboards",
    "README.md"
  ],
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavePujan/prometheus-auto-instrument.git"
  },
  "bin": {
    "prom-auto": "bin/cli.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./plugins/mongo": "./src/plugins/mongo.js",
    "./plugins/redis": "./src/plugins/redis.js",
    "./plugins/otel": "./src/plugins/otel.js"
  },
  "scripts": {
    "start:test": "node test-app.js",
    "test": "jest --runInBand",
    "release": "standard-version"
  },
  "keywords": [
    "prometheus",
    "monitoring",
    "observability",
    "metrics",
    "nodejs"
  ],
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "express": "^5.2.1",
    "on-finished": "^2.4.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "jest": "^30.0.5",
    "standard-version": "^9.5.0",
    "supertest": "^7.1.3"
  }
}
